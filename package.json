{
  "name": "wechat-claw",
  "version": "1.0.0",
  "description": "A powerful WeChat utility library",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "pnpm run build",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:real": "vitest run src/__test__/manual-integration.test.ts",
    "bot": "tsx examples/basic-bot.ts"
  },
  "keywords": [
    "wechat"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.28.0",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "qrcode-terminal": "^0.12.0",
    "@types/qrcode-terminal": "^0.12.2",
    "tsdown": "^0.21.5",
    "tsx": "^4.19.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1",
    "@antfu/eslint-config": "^7.7.3",
    "eslint": "^10.0.3",
    "eslint-plugin-format": "^2.0.1"
  },
  "peerDependencies": {
    "qrcode-terminal": "^0.12.0"
  },
  "dependencies": {}
}